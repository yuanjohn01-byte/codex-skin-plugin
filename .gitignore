/.vscode/
/.idea/
/.history/
/.claude/
/.codex/
/.chats/
/.codex-skin-local/

# Personal notes, discussions, drafts, and Private-only material
/notes/
/personal/
/scratch/
/drafts/
/discussion/
/discussions/
/transcripts/
/prompts/
/outputs/
/logs/
/screenshots/
/recordings/
/videos/

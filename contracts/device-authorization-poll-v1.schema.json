{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yuanjohn01-byte/codex-skin-plugin/blob/main/contracts/device-authorization-poll-v1.schema.json",
  "title": "Codex Skin device authorization poll contract v1",
  "description": "Public request and response contract for Helper device authorization polling, cancellation, token issuance, refresh rotation, device-limit recovery, and logout.",
  "x-endpoints": {
    "poll": "/api/v1/plugin/device-authorizations/token",
    "cancel": "/api/v1/plugin/device-authorizations/cancel",
    "refresh": "/api/v1/plugin/token/refresh",
    "logout": "/api/v1/plugin/logout"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/proofRequest"
    },
    {
      "$ref": "#/$defs/pollErrorEnvelope"
    },
    {
      "$ref": "#/$defs/cancelSuccessEnvelope"
    },
    {
      "$ref": "#/$defs/tokenSuccessEnvelope"
    },
    {
      "$ref": "#/$defs/refreshRequest"
    },
    {
      "$ref": "#/$defs/tokenErrorEnvelope"
    },
    {
      "$ref": "#/$defs/logoutSuccessEnvelope"
    },
    {
      "$ref": "#/$defs/logoutErrorEnvelope"
    }
  ],
  "$defs": {
    "proofRequest": {
      "type": "object",
      "required": ["deviceCode", "codeVerifier"],
      "properties": {
        "deviceCode": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "codeVerifier": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._~-]{43,128}$"
        }
      },
      "additionalProperties": false
    },
    "pollErrorEnvelope": {
      "type": "object",
      "required": ["error", "requestId"],
      "properties": {
        "error": {
          "type": "object",
          "required": [
            "code",
            "message",
            "action",
            "retryable",
            "incidentId",
            "details"
          ],
          "properties": {
            "code": {
              "enum": [
                "CS-AUTH-POLL-001",
                "CS-AUTH-POLL-002",
                "CS-AUTH-POLL-003",
                "CS-AUTH-POLL-004",
                "CS-AUTH-POLL-005",
                "CS-AUTH-POLL-006",
                "CS-AUTH-POLL-007",
                "CS-AUTH-POLL-008",
                "CS-AUTH-POLL-009",
                "CS-AUTH-POLL-010"
              ]
            },
            "message": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "action": {
              "enum": [
                "fix_request",
                "continue_polling",
                "reauthorize",
                "retry_later",
                "contact_support",
                "manage_devices"
              ]
            },
            "retryable": {
              "type": "boolean"
            },
            "incidentId": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^INC-[A-Z0-9]{12}$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "details": {
              "type": "object",
              "properties": {
                "state": {
                  "enum": [
                    "invalid_request",
                    "invalid_grant",
                    "authorization_pending",
                    "slow_down",
                    "expired_token",
                    "access_denied",
                    "authorization_consumed",
                    "device_limit_reached"
                  ]
                },
                "retryAfter": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 300
                },
                "managementUrl": {
                  "type": "string",
                  "pattern": "^https?://[^\\s]+/settings/devices$",
                  "maxLength": 2048
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "requestId": {
          "type": "string",
          "pattern": "^req_[a-f0-9]{32}$"
        }
      },
      "additionalProperties": false
    },
    "tokenSuccessEnvelope": {
      "type": "object",
      "required": ["data", "requestId"],
      "properties": {
        "data": {
          "type": "object",
          "required": [
            "tokenType",
            "accessToken",
            "expiresIn",
            "refreshToken",
            "device"
          ],
          "properties": {
            "tokenType": {
              "const": "Bearer"
            },
            "accessToken": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$",
              "minLength": 80,
              "maxLength": 8192
            },
            "expiresIn": {
              "const": 900
            },
            "refreshToken": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{43}$"
            },
            "device": {
              "type": "object",
              "required": ["id", "displayName"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^dev_[A-Za-z0-9_-]{32}$"
                },
                "displayName": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 80
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "requestId": {
          "type": "string",
          "pattern": "^req_[a-f0-9]{32}$"
        }
      },
      "additionalProperties": false
    },
    "refreshRequest": {
      "type": "object",
      "required": ["refreshToken", "deviceKey"],
      "properties": {
        "refreshToken": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "deviceKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        }
      },
      "additionalProperties": false
    },
    "tokenErrorEnvelope": {
      "type": "object",
      "required": ["error", "requestId"],
      "properties": {
        "error": {
          "type": "object",
          "required": [
            "code",
            "message",
            "action",
            "retryable",
            "incidentId",
            "details"
          ],
          "properties": {
            "code": {
              "enum": [
                "CS-AUTH-TOKEN-001",
                "CS-AUTH-TOKEN-002",
                "CS-AUTH-TOKEN-003",
                "CS-AUTH-TOKEN-004",
                "CS-AUTH-TOKEN-005",
                "CS-AUTH-TOKEN-006",
                "CS-AUTH-TOKEN-007"
              ]
            },
            "message": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "action": {
              "enum": [
                "fix_request",
                "reauthorize",
                "retry_later",
                "contact_support"
              ]
            },
            "retryable": {
              "type": "boolean"
            },
            "incidentId": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^INC-[A-Z0-9]{12}$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "details": {
              "type": "object",
              "properties": {
                "retryAfter": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 600
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "requestId": {
          "type": "string",
          "pattern": "^req_[a-f0-9]{32}$"
        }
      },
      "additionalProperties": false
    },
    "cancelSuccessEnvelope": {
      "type": "object",
      "required": ["data", "requestId"],
      "properties": {
        "data": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "const": "cancelled"
            }
          },
          "additionalProperties": false
        },
        "requestId": {
          "type": "string",
          "pattern": "^req_[a-f0-9]{32}$"
        }
      },
      "additionalProperties": false
    },
    "logoutSuccessEnvelope": {
      "type": "object",
      "required": ["data", "requestId"],
      "properties": {
        "data": {
          "type": "object",
          "required": ["deviceId", "status"],
          "properties": {
            "deviceId": {
              "type": "string",
              "pattern": "^dev_[A-Za-z0-9_-]{32}$"
            },
            "status": {
              "const": "logged_out"
            }
          },
          "additionalProperties": false
        },
        "requestId": {
          "type": "string",
          "pattern": "^req_[a-f0-9]{32}$"
        }
      },
      "additionalProperties": false
    },
    "logoutErrorEnvelope": {
      "type": "object",
      "required": ["error", "requestId"],
      "properties": {
        "error": {
          "type": "object",
          "required": [
            "code",
            "message",
            "action",
            "retryable",
            "incidentId",
            "details"
          ],
          "properties": {
            "code": {
              "enum": [
                "CS-AUTH-LOGOUT-001",
                "CS-AUTH-LOGOUT-002",
                "CS-AUTH-LOGOUT-003",
                "CS-AUTH-LOGOUT-004"
              ]
            },
            "message": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "action": {
              "enum": ["fix_request", "reauthorize", "contact_support"]
            },
            "retryable": {
              "const": false
            },
            "incidentId": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^INC-[A-Z0-9]{12}$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "details": {
              "type": "object",
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "requestId": {
          "type": "string",
          "pattern": "^req_[a-f0-9]{32}$"
        }
      },
      "additionalProperties": false
    }
  }
}
